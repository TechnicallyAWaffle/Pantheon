}

.empty-space {
    flex-grow: 1;
    background-image: url("project://database/Assets/UI/Textures/Player/box_dotted_green.png?fileID=2800000&guid=9f98b9744ad486e4d96b4c970614b233&type=3#box_dotted_green");
    -unity-slice-left: 1;
    -unity-slice-top: 1;
    -unity-slice-right: 1;
    -unity-slice-bottom: 1;
    border-bottom-width: 0;
    margin-bottom: 14px;
    margin-top: 14px;
    padding-right: 10px;
    margin-right: 6px;
    margin-left: 6px;
    padding-top: 10px;
    padding-bottom: 10px;
    padding-left: 10px;
}

/* ProgressBar root container */
#ProgressBar {
    height: 20px;
    margin: 4px 0;
}

/* The grey background track */
#ProgressBar .unity-progress-bar__background {
    background-color:rgb(13, 88, 46);

    border-radius: 4px;
    border-width: 1px;
    border-color: rgb(0, 51, 22);
}

/* The colored fill — this is what moves */
#ProgressBar .unity-progress-bar__progress {
    background-color:rgb(128, 209, 165);

    border-radius: 4px;
}
