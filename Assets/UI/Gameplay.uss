:root {
}

.header {
    -unity-font-definition: url("project://database/Assets/UI/Fonts/Ac437_Amstrad_PC.ttf?fileID=12800000&guid=73bf2caab17f78045b5efd28483d3a8a&type=3#Ac437_Amstrad_PC");
    font-size: 22%;
}

.unity-progress-bar {
}

.body {
    -unity-font-definition: url("project://database/Assets/UI/Fonts/Ac437_MBytePC230_CGA.ttf?fileID=12800000&guid=67fc1b1210bc8a040bff1f6ff10f2e0a&type=3#Ac437_MBytePC230_CGA");
    color: rgb(128, 209, 165);
    -unity-text-align: middle-center;
}

.compute {
    -unity-font-definition: url("project://database/Assets/UI/Fonts/Ac437_Amstrad_PC.ttf?fileID=12800000&guid=73bf2caab17f78045b5efd28483d3a8a&type=3#Ac437_Amstrad_PC");
    font-size: 52px;
}

.boxed-text {
    -unity-text-align: middle-center;
    margin-top: 2px;
    margin-right: 0;
    margin-bottom: 2px;
    margin-left: 0;
    padding-top: 3px;
    padding-right: 4px;
    padding-bottom: 3px;
    padding-left: 4px;
    align-content: center;
    align-self: center;
    color: rgb(128, 209, 165);
    -unity-font-definition: url("project://database/Assets/UI/Fonts/Ac437_Amstrad_PC.ttf?fileID=12800000&guid=73bf2caab17f78045b5efd28483d3a8a&type=3#Ac437_Amstrad_PC");
    height: auto;
    width: auto;
    background-image: url("project://database/Assets/UI/Textures/Player/box_encryption_light_green.png?fileID=2800000&guid=4a8e6057ad1aeb944b12618ab490b8ae&type=3#box_encryption_light_green");
    -unity-background-image-tint-color: rgb(255, 255, 255);
    -unity-slice-left: 4;
    -unity-slice-top: 4;
    -unity-slice-right: 4;
    -unity-slice-bottom: 4;
    font-size: 10px;
}

#CommandLine .unity-base-text-field__input {
    background-color: rgba(0, 0, 0, 0);
    border-color: rgba(0, 0, 0, 0);
}

#CommandLine .unity-base-text-field__input > .unity-text-element {
    -unity-font-definition: url("project://database/Assets/UI/Fonts/Ac437_Amstrad_PC.ttf?fileID=12800000&guid=73bf2caab17f78045b5efd28483d3a8a&type=3#Ac437_Amstrad_PC");
    color: rgb(128, 209, 165);
    font-size: 16px;
}

.hidden {
    display: none;
}

.none-encryption {
    flex-grow: 1;
    background-image: url("project://database/Assets/UI/Textures/Player/box_encryption_none_green.png?fileID=2800000&guid=bb05ca91299253c47a3410b74ca159c5&type=3#box_encryption_none_green");
    -unity-slice-left: 8;
    -unity-slice-top: 8;
    -unity-slice-right: 8;
    -unity-slice-bottom: 8;
    border-bottom-width: 0;
    margin-bottom: 14px;
    margin-top: 14px;
    padding-right: 10px;
    margin-right: 6px;
    margin-left: 6px;
    padding-top: 10px;
    padding-bottom: 10px;
    padding-left: 10px;
}

.light-encryption {
    flex-grow: 1;
    background-image: url("project://database/Assets/UI/Textures/Player/box_encryption_light_green.png?fileID=2800000&guid=4a8e6057ad1aeb944b12618ab490b8ae&type=3#box_encryption_light_green");
    -unity-slice-left: 4;
    -unity-slice-top: 4;
    -unity-slice-right: 4;
    -unity-slice-bottom: 4;
    border-bottom-width: 0;
    margin-bottom: 14px;
    margin-top: 14px;
    padding-right: 10px;
    margin-right: 6px;
    margin-left: 6px;
    padding-top: 10px;
    padding-bottom: 10px;
    padding-left: 10px;
}

.medium-encryption {
    flex-grow: 1;
    background-image: url("project://database/Assets/UI/Textures/Player/box_encryption_medium_green.png?fileID=2800000&guid=f29b5a34e690a484e893bc2ee8afde10&type=3#box_encryption_medium_green");
    -unity-slice-left: 4;
    -unity-slice-top: 4;
    -unity-slice-right: 4;
    -unity-slice-bottom: 4;
    border-bottom-width: 0;
    margin-bottom: 14px;
    margin-top: 14px;
    padding-right: 0;
    margin-right: 6px;
    margin-left: 6px;
}

.high-encryption {
    flex-grow: 1;
    background-image: url("project://database/Assets/UI/Textures/Player/box_encryption_high_green.png?fileID=2800000&guid=35cfa24358f63f945b8e7bfaa5f196f6&type=3#box_encryption_high_green");
    -unity-slice-left: 4;
    -unity-slice-top: 4;
    -unity-slice-right: 4;
    -unity-slice-bottom: 4;
    border-bottom-width: 0;
    margin-bottom: 14px;
    margin-top: 14px;
    padding-right: 10px;
    margin-right: 6px;
    margin-left: 6px;
    padding-top: 10px;
    padding-bottom: 10px;
